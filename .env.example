# ==========================================
# Archivo de Ejemplo de Variables de Entorno
# ==========================================
# Crea una copia de este archivo, renómbralo a '.env' y ajusta los valores de tu servidor.

# Configuración del servidor web API (Flask)
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_ENV=development

# Configuración del motor de Web Scraping (Playwright)
# True = Oculto / Rendimiento alto (Servidor)
# False = Gráfico / Debug
SCRAPER_HEADLESS=True
